# SMTP Configuration
# Required: SMTP server hostname
SMTP_HOST=smtp.gmail.com

# Required: SMTP server port (587 for STARTTLS, 465 for SSL/TLS)
SMTP_PORT=587

# Optional: Whether to use secure connection (true/false or 1/0)
# If not set, auto-detected: port 465 = true, others = false
SMTP_SECURE=false

# Required: SMTP authentication username
SMTP_USER=your-email@gmail.com

# Required: SMTP authentication password or app password
SMTP_PASS=your-app-password

# Email Configuration
# Required: Domain for constructing sender email addresses
# Emails will be sent from {fromName}@{EMAIL_DOMAIN}
EMAIL_DOMAIN=mail.hack-tues.com

# Optional: Reply-to address for all emails
# If not set, reply-to field will be undefined
REPLY_TO_ADDRESS=hacktues@elsys-bg.org

# Required: Test recipient email address for connection verification
# Used in bulkSendHT to send a test email before bulk sending
TEST_RECIPIENT=test@example.com
